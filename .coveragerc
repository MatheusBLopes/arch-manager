[run]
source = arch_manager
omit =
    */migrations/*
    */__pycache__/*
    manage.py
    asgi.py
    wsgi.py
    */management/commands/seed_*.py
    conftest.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
